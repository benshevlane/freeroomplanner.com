{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.freeroomplanner.com"
        }
      ],
      "destination": "https://freeroomplanner.com/:path",
      "permanent": true
    },
    {
      "source": "/for-businesses",
      "destination": "/get-embed",
      "permanent": true
    },
    {
      "source": "/floor-plan",
      "destination": "/floor-plan-maker",
      "permanent": true
    },
    {
      "source": "/blog/best-free-online-kitchen-planner",
      "destination": "/blog/best-free-online-kitchen-planner-no-sign-up",
      "permanent": true
    },
    {
      "source": "/blog/free-2d-floor-plan-creator-simple-beats-complex",
      "destination": "/blog/free-2d-floor-plan-creator",
      "permanent": true
    },
    {
      "source": "/blog/garage-conversion-planner-free-tool",
      "destination": "/blog/how-to-plan-a-garage-conversion-floor-plan-guide",
      "permanent": true
    },
    {
      "source": "/blog/loft-conversion-planning-tool-free-floor-plan-software-uk",
      "destination": "/blog/loft-conversion-planning-tool-free-floor-plan-guide",
      "permanent": true
    },
    {
      "source": "/blog/best-room-planner-app-no-sign-up",
      "destination": "/blog/room-planner-app-no-sign-up",
      "permanent": true
    },
    {
      "source": "/free-kitchen-planner",
      "destination": "/blog/best-free-online-kitchen-planner-no-sign-up",
      "permanent": true
    },
    {
      "source": "/free-kitchen-planner-online",
      "destination": "/blog/best-free-online-kitchen-planner-no-sign-up",
      "permanent": true
    },
    {
      "source": "/kitchen-design-tool-online",
      "destination": "/blog/best-free-online-kitchen-planner-no-sign-up",
      "permanent": true
    },
    {
      "source": "/bedroom-layout-planner",
      "destination": "/bedroom-planner",
      "permanent": true
    },
    {
      "source": "/house-floor-plan-creator",
      "destination": "/floor-plan-maker",
      "permanent": true
    },
    {
      "source": "/home-office-layout-planner",
      "destination": "/blog/home-office-layout-planner",
      "permanent": true
    },
    {
      "source": "/kitchen-island-layout-planner",
      "destination": "/blog/kitchen-island-layout-planner",
      "permanent": true
    },
    {
      "source": "/small-bathroom-layout-ideas-6x8",
      "destination": "/blog/small-bathroom-layout-ideas-6x8",
      "permanent": true
    },
    {
      "source": "/kitchen-extension-planning",
      "destination": "/blog/how-to-plan-a-kitchen-renovation",
      "permanent": true
    },
    {
      "source": "/blog/ikea-pax-planner-uk-how",
      "destination": "/blog/ikea-pax-planner-uk-plan",
      "permanent": true
    },
    {
      "source": "/blog/ikea-pax-planner-uk-plan-your-perfect-wardrobe-free-tools-tips",
      "destination": "/blog/ikea-pax-planner-uk-plan",
      "permanent": true
    },
    {
      "source": "/blog/ikea-pax-planner-uk",
      "destination": "/blog/ikea-pax-planner-uk-plan",
      "permanent": true
    },
    {
      "source": "/best-free-online-bathroom-planners",
      "destination": "/bathroom-planner",
      "permanent": true
    },
    {
      "source": "/how-to-draw-floor-plans-accurately",
      "destination": "/floor-plan-maker",
      "permanent": true
    },
    {
      "source": "/best-room-planner-app-for-renovations",
      "destination": "/room-planner",
      "permanent": true
    },
    {
      "source": "/small-bathroom-layout",
      "destination": "/blog/small-bathroom-layout-ideas-6x8",
      "permanent": true
    },
    {
      "source": "/floor-plan-maker-contractors",
      "destination": "/blog/floor-plan-maker-contractors",
      "permanent": true
    },
    {
      "source": "/room-planner-app-no-sign-up",
      "destination": "/blog/room-planner-app-no-sign-up",
      "permanent": true
    },
    {
      "source": "/small-bathroom-layout-planner",
      "destination": "/blog/small-bathroom-layout-planner",
      "permanent": true
    }
  ],
  "buildCommand": "npx vite build && node scripts/postbuild.mjs",
  "outputDirectory": "dist/public",
  "framework": null,
  "headers": [
    {
      "source": "/embed",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(woff2|woff|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|avif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000"
        }
      ]
    },
    {
      "source": "/rs.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}